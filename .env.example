# Plivo credentials (get from Plivo Console → Overview)
PLIVO_AUTH_ID=your_auth_id_here
PLIVO_AUTH_TOKEN=your_auth_token_here

# Your Plivo phone number (with country code, e.g. +918035736861)
PLIVO_FROM_NUMBER=+1XXXXXXXXXX

# Your birthdate in DDMM format (e.g. March 15 → 1503)
VALID_OTP=1503

# A placeholder number to forward calls to (with country code)
ASSOCIATE_NUMBER=+1XXXXXXXXXX

# Your ngrok public URL — update this every time you restart ngrok
# Example: https://abc123.ngrok.io
BASE_URL=https://your-ngrok-url.ngrok.io
